{
  "manifest_version": 3,
  "name": "Website Time Limiter",
  "version": "1.1",
  "description": "Set daily time limits for any website to boost productivity.",
  "permissions": [
    "storage",
    "webNavigation",
    "tabs",
    "notifications",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/background.js"
  },
  "action": {
    "default_popup": "ui/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js", "content/reconnect.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["ui/blocked/blocked.html", "ui/blocked/blocked.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
