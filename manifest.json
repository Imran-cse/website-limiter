{
  "manifest_version": 3,
  "name": "Website Time Limiter",
  "version": "1.1",
  "description": "Set daily time limits for any website to boost productivity.",
  "permissions": [
    "storage",
    "webNavigation",
    "tabs",
    "notifications",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js", "reconnect.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
