{
  "manifest_version": 3,
  "name": "FocusGuard — Website Blocker & Time Limit",
  "short_name": "FocusGuard",
  "author": "Imran Hossain",
  "version": "1.1.2",
  "description": "Website blocker for focus & productivity. Set a daily time limit on any site and get blocked when your time runs out.",
  "permissions": [
    "storage",
    "webNavigation",
    "tabs",
    "notifications",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/background.js"
  },
  "action": {
    "default_popup": "ui/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js", "content/reconnect.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["ui/blocked/blocked.html", "ui/blocked/blocked.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "120": "icons/icon120.png",
    "128": "icons/icon128.png"
  }
}
